      "services": [
        {
          "unit": "vps-sentry-web.service",
          "label": "Public dashboard",
          "domain": "vps-sentry.tokentap.ca",
          "health_urls": [
            "https://vps-sentry.tokentap.ca/api/readyz",
            "http://127.0.0.1:3035/api/readyz"
          ],
          "impact": "The VPS Sentry dashboard and API go dark behind nginx until the web service is restored.",
          "runbook": "systemctl status vps-sentry-web.service --no-pager -l && journalctl -u vps-sentry-web.service -n 80 --no-pager",
          "open_title": "VPS Sentry dashboard inactive",
          "recovery_title": "VPS Sentry dashboard restored",
          "severity": "critical"
        },
        {
          "unit": "vps-sentry-ops-worker.service",
