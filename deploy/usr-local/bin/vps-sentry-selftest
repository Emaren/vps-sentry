#!/usr/bin/env bash
set -euo pipefail

SENTRY="/usr/local/bin/vps-sentry"
SHIP="/usr/local/bin/vps-sentry-ship"
NOTIFY="/usr/local/bin/vps-sentry-notify"
SERVICE_EVENT="/usr/local/bin/vps-sentry-service-event"
MAINTENANCE="/usr/local/bin/vps-sentry-maintenance"
PROJECT_STORAGE="/usr/local/bin/vps-sentry-project-storage"
GARBAGE_ESTIMATE="/usr/local/bin/vps-sentry-garbage-estimate"
GARBAGE_RECLAIM="/usr/local/bin/vps-sentry-garbage-reclaim"
COUNTERSTRIKE="/usr/local/bin/vps-sentry-counterstrike"

STATE_DIR="/var/lib/vps-sentry"
LAST_JSON="$STATE_DIR/last.json"
MARKER="$STATE_DIR/last_shipped_ts.txt"

DROPIN="/etc/systemd/system/vps-sentry.service.d/90-post.conf"
TMP_UNIT="/etc/systemd/system/zzz-vps-sentry-selftest.service"
TMP_UNIT_OLD="/etc/systemd/system/zzz-tripwire.service"
TEST_TRIP="$STATE_DIR/test/tripwire.txt"
CONFIG_JSON="/etc/vps-sentry.json"
PROJECTS_FILE="/etc/vps-sentry-projects.json"
EVENT_UNIT="/etc/systemd/system/vps-sentry-unit-event@.service"
WEB_EVENT_DROPIN="/etc/systemd/system/vps-sentry-web.service.d/10-vps-sentry-events.conf"
PUBLIC_STATUS_DIR="$STATE_DIR/public"
PUBLIC_STATUS_FILE="$PUBLIC_STATUS_DIR/status.json"
PUBLIC_LAST_FILE="$PUBLIC_STATUS_DIR/last.json"
PUBLIC_DIFF_FILE="$PUBLIC_STATUS_DIR/diff.json"
SUDOERS_FILE="/etc/sudoers.d/90-vps-sentry-maintenance"

WITH_NETWORK=0

usage() {
  cat <<'EOF'
Usage: vps-sentry-selftest [--with-network]

Default mode validates deterministic local behavior only.
Use --with-network to additionally require successful webhook shipping.
EOF
}

die() { echo "FAIL: $*" >&2; exit 1; }

json_alerts_summary() {
  python3 - "$LAST_JSON" <<'PY'
import json, sys
p=sys.argv[1]
try:
  d=json.load(open(p,"r"))
except Exception as e:
  print(f"(could not read {p}: {e})")
  sys.exit(0)

alerts=d.get("alerts", [])
print(f"alerts_type={type(alerts).__name__}")
if isinstance(alerts, list):
  print(f"alerts_count={len(alerts)}")
  for a in alerts:
    if not isinstance(a, dict):
      continue
    title=(a.get("title") or "").strip()
    detail=(a.get("detail") or "").strip()
    print(f"- {title}")
    if detail:
      lines=[ln.rstrip() for ln in detail.splitlines() if ln.strip()]
      for ln in lines[:14]:
        print(f"  {ln}")
      if len(lines) > 14:
        print("  ...")
else:
  print(f"alerts_value={alerts!r}")
PY
}

only_test_tripwire_alerts() {
  # returns 0 if ONLY alerts are "Watched files changed" and every changed path is under /var/lib/vps-sentry/test/
  python3 - "$LAST_JSON" <<'PY'
import json, sys
p=sys.argv[1]
d=json.load(open(p,"r"))
alerts=d.get("alerts", [])
if not isinstance(alerts, list):
  sys.exit(1)

changed=[]
saw=False

for a in alerts:
  if not isinstance(a, dict):
    continue
  title=(a.get("title") or "").strip().lower()
  detail=(a.get("detail") or "")
  if title != "watched files changed":
    sys.exit(2)
  saw=True
  for ln in detail.splitlines():
    ln=ln.strip()
    if not ln or ln.lower().startswith("changed"):
      continue
    if ln.startswith("/"):
      changed.append(ln)

if not saw or not changed:
  sys.exit(3)

ok = all(p.startswith("/var/lib/vps-sentry/test/") for p in changed)
sys.exit(0 if ok else 4)
PY
}

watched_alert_mentions_path() {
  local path="$1"
  python3 - "$LAST_JSON" "$path" <<'PY'
import json, sys
p=sys.argv[1]
target=sys.argv[2]
d=json.load(open(p,"r"))
alerts=d.get("alerts", [])
if not isinstance(alerts, list):
  sys.exit(1)

for a in alerts:
  if not isinstance(a, dict):
    continue
  title=(a.get("title") or "").strip().lower()
  detail=(a.get("detail") or "")
  if title != "watched files changed":
    continue
  for ln in detail.splitlines():
    if ln.strip() == target:
      sys.exit(0)

sys.exit(2)
PY
}

has_webhook_config() {
  python3 - "$CONFIG_JSON" <<'PY'
import json, sys
p=sys.argv[1]
try:
  cfg=json.load(open(p,"r"))
except Exception:
  sys.exit(2)

def walk(x):
  if isinstance(x, dict):
    for v in x.values():
      yield from walk(v)
  elif isinstance(x, list):
    for v in x:
      yield from walk(v)
  elif isinstance(x, str):
    yield x

for s in walk(cfg):
  if "discord.com/api/webhooks/" in s or "discordapp.com/api/webhooks/" in s:
    sys.exit(0)

sys.exit(1)
PY
}

accept_baseline_best_effort() {
  # We don't know the exact flag name on your build, so try a few common ones.
  for cmd in \
    "$SENTRY --accept-baseline" \
    "$SENTRY --accept" \
    "$SENTRY --baseline-accept" \
    "$SENTRY --accept_baseline" \
    "$SENTRY accept" \
    "$SENTRY baseline accept"
  do
    if $cmd >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

cleanup() {
  rm -f "$TMP_UNIT" "$TMP_UNIT_OLD" 2>/dev/null || true
  systemctl daemon-reload >/dev/null 2>&1 || true
}

service_user_for_unit() {
  systemctl show -p User --value "$1" 2>/dev/null | tr -d '[:space:]'
}

user_can_access_paths() {
  local service_user="$1"
  shift || true
  python3 - "$service_user" "$@" <<'PY'
import grp
import os
import pwd
import stat
import sys

user = sys.argv[1]
paths = sys.argv[2:]

try:
    pw = pwd.getpwnam(user)
except KeyError:
    raise SystemExit(2)

uid = pw.pw_uid
groups = {pw.pw_gid}
for entry in grp.getgrall():
    if user in entry.gr_mem:
        groups.add(entry.gr_gid)

def has_access(path: str, want_exec: bool) -> bool:
    try:
        st = os.stat(path)
    except OSError:
        return False
    if uid == 0:
        return True
    if uid == st.st_uid:
        mask = stat.S_IXUSR if want_exec else stat.S_IRUSR
    elif st.st_gid in groups:
        mask = stat.S_IXGRP if want_exec else stat.S_IRGRP
    else:
        mask = stat.S_IXOTH if want_exec else stat.S_IROTH
    return bool(st.st_mode & mask)

checks = [(paths[0], True), (paths[1], True), (paths[2], False), (paths[3], False), (paths[4], False)]
for path, want_exec in checks:
    if not has_access(path, want_exec):
        raise SystemExit(1)
PY
}

assert_public_status_readable() {
  local service_user="$1"
  [[ -n "$service_user" ]] || die "missing service user for public status readability check"
  user_can_access_paths \
    "$service_user" \
    "$STATE_DIR" \
    "$PUBLIC_STATUS_DIR" \
    "$PUBLIC_STATUS_FILE" \
    "$PUBLIC_LAST_FILE" \
    "$PUBLIC_DIFF_FILE" || die "$service_user cannot traverse $STATE_DIR/public and read published status files"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --with-network)
      WITH_NETWORK=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      die "unknown argument: $1"
      ;;
  esac
  shift
done

trap cleanup EXIT

echo "== vps-sentry selftest =="
if (( WITH_NETWORK )); then
  echo "Mode: local + network shipping assertions"
else
  echo "Mode: deterministic local checks (network shipping assertion disabled)"
fi

echo
echo "== 1) binaries =="
test -x "$SENTRY" || die "missing or not executable: $SENTRY"
test -x "$SHIP"  || die "missing or not executable: $SHIP"
test -x "$NOTIFY" || die "missing or not executable: $NOTIFY"
test -x "$SERVICE_EVENT" || die "missing or not executable: $SERVICE_EVENT"
test -x "$MAINTENANCE" || die "missing or not executable: $MAINTENANCE"
test -x "$PROJECT_STORAGE" || die "missing or not executable: $PROJECT_STORAGE"
test -x "$COUNTERSTRIKE" || die "missing or not executable: $COUNTERSTRIKE"
"$SENTRY" --version || true

echo
echo "== 2) systemd wiring =="
systemctl is-enabled vps-sentry.timer >/dev/null || die "vps-sentry.timer is not enabled"
systemctl cat vps-sentry.service --no-pager >/dev/null || die "cannot read vps-sentry.service"
test -f "$DROPIN" || die "missing drop-in: $DROPIN"
grep -Eq "ExecStartPost=.*vps-sentry-ship" "$DROPIN" || die "drop-in does not reference vps-sentry-ship: $DROPIN"
grep -Eq "ExecStartPost=.*vps-sentry-project-storage" "$DROPIN" || die "drop-in does not reference vps-sentry-project-storage: $DROPIN"
grep -Eq "ExecStartPost=.*vps-sentry-garbage-estimate" "$DROPIN" || die "drop-in does not reference vps-sentry-garbage-estimate: $DROPIN"
test -f "$EVENT_UNIT" || die "missing unit template: $EVENT_UNIT"
grep -Eq 'Description=.*%i' "$EVENT_UNIT" || die "unit template description must use %i: $EVENT_UNIT"
grep -Eq 'ExecStart=.*--spec %i' "$EVENT_UNIT" || die "unit template ExecStart must use %i: $EVENT_UNIT"
test -f "$WEB_EVENT_DROPIN" || die "missing web event drop-in: $WEB_EVENT_DROPIN"
python3 - "$PROJECTS_FILE" <<'PY' || die "missing disk storage roots for vps-sentry in $PROJECTS_FILE"
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
payload = json.loads(path.read_text())
projects = payload.get("projects")
if not isinstance(projects, list):
    raise SystemExit(1)

for project in projects:
    if not isinstance(project, dict):
        continue
    if project.get("id") != "vps-sentry":
        continue
    storage = project.get("storage")
    roots = storage.get("roots") if isinstance(storage, dict) else None
    if isinstance(roots, list) and any(str(root).strip() for root in roots):
        raise SystemExit(0)
    raise SystemExit(2)

raise SystemExit(3)
PY

echo
echo "== 3) ship script perms/owner =="
stat -c '%U %G %a %n' "$SHIP"
[[ "$(stat -c '%U:%G' "$SHIP")" == "root:root" ]] || die "ship script is not owned by root:root"
[[ "$(stat -c '%a' "$SHIP")" == "755" ]] || die "ship script perms not 755"

echo
echo "== 4) cleanup old selftest artifacts =="
cleanup

echo
echo "== 4b) maintenance token smoke =="
"$MAINTENANCE" start --scope vps-sentry-selftest.service --ttl 30s --reason selftest >/dev/null
"$MAINTENANCE" is-active --scope vps-sentry-selftest.service || die "maintenance scope did not become active"
"$MAINTENANCE" stop --scope vps-sentry-selftest.service >/dev/null
if "$MAINTENANCE" is-active --scope vps-sentry-selftest.service; then
  die "maintenance scope still active after stop"
fi

echo
echo "== 4c) counterstrike wiring smoke =="
test -f "$SUDOERS_FILE" || die "missing sudoers file: $SUDOERS_FILE"
grep -Eq 'vps-sentry-counterstrike' "$SUDOERS_FILE" || die "sudoers file does not allow vps-sentry-counterstrike"
COUNTERSTRIKE_JSON="$("$COUNTERSTRIKE" --mode analyze --json)" || die "counterstrike analyze mode failed"
python3 - <<'PY' "$COUNTERSTRIKE_JSON"
import json
import sys

payload = json.loads(sys.argv[1])
if payload.get("playbook") != "zap-01-miner-persistence-purge":
    raise SystemExit("unexpected counterstrike playbook")
if payload.get("status") not in {"analysis_only", "contained", "failed"}:
    raise SystemExit(f"unexpected counterstrike status: {payload.get('status')!r}")
planned = payload.get("planned_actions")
if not isinstance(planned, dict):
    raise SystemExit("counterstrike result missing planned_actions")
required = {"candidate_count", "stop_pids", "quarantine_paths", "cron_removed_lines", "cron_changed_targets"}
missing = sorted(required - planned.keys())
if missing:
    raise SystemExit(f"counterstrike planned_actions missing keys: {', '.join(missing)}")
PY

echo
echo "== 5) baseline run + attempt to accept clean baseline =="
systemctl start vps-sentry.service
test -f "$LAST_JSON" || die "missing $LAST_JSON after running service"

if accept_baseline_best_effort; then
  echo "Baseline accept: OK"
  systemctl start vps-sentry.service
else
  echo "Baseline accept: (no known accept flag worked) - continuing anyway"
  echo "If step 6 fails, baseline still includes real watched changes."
fi

echo
echo "Current alerts summary (post-baseline attempt):"
json_alerts_summary

echo
echo "== 5b) published dashboard status invariants =="
[[ "$(stat -c '%a' "$STATE_DIR")" == "711" ]] || die "$STATE_DIR mode drifted (expected 711)"
if systemctl is-active --quiet vps-sentry-web.service; then
  WEB_USER="$(service_user_for_unit vps-sentry-web.service)"
  assert_public_status_readable "$WEB_USER"
  READY_JSON="$(curl -fsS http://127.0.0.1:3035/api/readyz?check=status)" || die "readyz status probe failed"
  python3 - <<'PY' "$READY_JSON"
import json
import sys

payload = json.loads(sys.argv[1])
if not payload.get("ok"):
    raise SystemExit("readyz returned ok=false")
status = (payload.get("checks") or {}).get("status") or {}
if not status.get("ok"):
    raise SystemExit("readyz status check reported unreadable published status files")
PY
else
  echo "Skipping dashboard readability check: vps-sentry-web.service inactive"
fi

# marker before
BEFORE=""
if [[ -f "$MARKER" ]]; then BEFORE="$(cat "$MARKER")"; fi
echo
echo "Ship marker BEFORE: ${BEFORE:-<empty>}"

echo
echo "== 6) TEST change under /var/lib/vps-sentry/test (should NOT ship bundle) =="
mkdir -p "$(dirname "$TEST_TRIP")"
echo "tripwire $(date -Is)" >> "$TEST_TRIP"
systemctl start vps-sentry.service

if ! only_test_tripwire_alerts; then
  echo
  echo "Selftest cannot validate suppression because alerts are not test-only."
  echo "You still have real watched changes pending (e.g. /etc/systemd/system)."
  echo
  echo "Alerts summary:"
  json_alerts_summary
  die "make baseline clean (accept), then rerun selftest"
fi

AFTER=""
if [[ -f "$MARKER" ]]; then AFTER="$(cat "$MARKER")"; fi
echo "Ship marker AFTER test-tripwire: ${AFTER:-<empty>}"

if [[ "$AFTER" != "$BEFORE" ]]; then
  die "ship marker changed on test-only tripwire (expected no bundle upload). before=$BEFORE after=$AFTER"
fi
echo "PASS: marker unchanged (no bundle upload) for test-only tripwire."

echo
echo "== 7) REAL watched change (must alert; shipping assert optional) =="
echo "# selftest $(date -Is)" >> "$TMP_UNIT"
systemctl daemon-reload >/dev/null 2>&1 || true
systemctl start vps-sentry.service

if ! watched_alert_mentions_path "$TMP_UNIT"; then
  echo
  echo "Alerts summary:"
  json_alerts_summary
  die "expected watched-files alert to include $TMP_UNIT"
fi
echo "PASS: watched-files alert includes $TMP_UNIT"

NEW=""
if [[ -f "$MARKER" ]]; then NEW="$(cat "$MARKER")"; fi
echo "Ship marker NEW: ${NEW:-<empty>}"

if (( WITH_NETWORK )); then
  has_webhook_config || die "--with-network requires a valid webhook in $CONFIG_JSON"
  if [[ -z "$NEW" || "$NEW" == "$BEFORE" ]]; then
    echo
    echo "Alerts summary:"
    json_alerts_summary
    die "ship marker did not change on real watched change (expected bundle upload). before=$BEFORE new=$NEW"
  fi
  echo "PASS: marker updated on real watched change."
else
  if [[ "$NEW" == "$BEFORE" ]]; then
    echo "PASS: real watched change alert detected (network shipping assertion skipped)."
  else
    echo "INFO: marker updated; webhook shipping appears active."
  fi
fi

echo
echo "ALL PASS"
