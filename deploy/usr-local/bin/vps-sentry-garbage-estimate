PROJECT_REGISTRY_CACHE: list[dict[str, object]] | None = None


def log(message: str) -> None:
    print(f"[VPS-GARBAGE] {message}", file=sys.stderr)


def iso_utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_iso(ts: object) -> datetime | None:
    if not isinstance(ts, str) or not ts.strip():
        return None
    raw = ts.strip()
    try:
        if raw.endswith("Z"):
            raw = raw[:-1] + "+00:00"
        return datetime.fromisoformat(raw)
    except ValueError:
        return None


def parse_csv_paths(raw: str | None) -> list[Path]:
    if not raw:
        return []
    out: list[Path] = []
    for part in raw.split(","):
        candidate = Path(part.strip())
        if not str(candidate).strip():
            continue
        out.append(candidate)
    return out


def default_home_roots() -> list[Path]:
    out: list[Path] = []
    if Path("/root").exists():
        out.append(Path("/root"))
    home_root = Path("/home")
    if home_root.is_dir():
        for child in sorted(home_root.iterdir()):
            if child.is_dir():
                out.append(child)
    return out


def home_roots() -> list[Path]:
    configured = parse_csv_paths(os.environ.get("VPS_SENTRY_GARBAGE_HOME_ROOTS"))
    roots = configured or default_home_roots()
    return [root for root in roots if root.exists() and root.is_dir()]


def scan_roots() -> list[Path]:
    configured = parse_csv_paths(os.environ.get("VPS_SENTRY_GARBAGE_SCAN_ROOTS"))
    roots = configured or [Path("/var/www"), Path("/root"), Path("/home")]
    return [root for root in roots if root.exists()]


def backup_roots() -> list[Path]:
    configured = parse_csv_paths(os.environ.get("VPS_SENTRY_GARBAGE_BACKUP_DIRS"))
    if configured:
        return [root for root in configured if root.exists() and root.is_dir()]
    defaults = [Path("/home/tony/_backup/vps-sentry-web")]
    return [root for root in defaults if root.exists() and root.is_dir()]


def age_seconds_for(path: Path) -> float:
    try:
        return max(0.0, datetime.now(timezone.utc).timestamp() - path.stat(follow_symlinks=False).st_mtime)
    except OSError:
        return 0.0


def load_json(path: Path) -> dict[str, object] | None:
    if not path.exists():
        return None
    try:
        payload = json.loads(path.read_text())
    except Exception:
        return None
    if not isinstance(payload, dict):
        return None
    return payload


def normalize_path_text(path: Path | str) -> str:
    path_obj = path if isinstance(path, Path) else Path(path)
    try:
        if path_obj.exists():
            return str(path_obj.resolve())
    except OSError:
        pass
    return str(path_obj)


def load_project_registry() -> list[dict[str, object]]:
    global PROJECT_REGISTRY_CACHE
    if PROJECT_REGISTRY_CACHE is not None:
        return PROJECT_REGISTRY_CACHE

    payload = load_json(PROJECTS_JSON) or {}
    rows = payload.get("projects")
    if not isinstance(rows, list):
        PROJECT_REGISTRY_CACHE = []
        return PROJECT_REGISTRY_CACHE

    projects: list[dict[str, object]] = []
    for row in rows:
        if not isinstance(row, dict):
            continue

        storage = row.get("storage")
        storage_roots: list[str] = []
        if isinstance(storage, dict):
            roots = storage.get("roots")
            if isinstance(roots, list):
                for raw_root in roots:
                    if isinstance(raw_root, str) and raw_root.strip():
                        storage_roots.append(normalize_path_text(raw_root.strip()))

        services_raw = row.get("services")
        service_refs: list[str] = []
        if isinstance(services_raw, list):
            for service in services_raw:
                if not isinstance(service, dict):
                    continue
                unit = service.get("unit")
                if isinstance(unit, str) and unit.strip():
                    service_refs.append(unit.strip())

        projects.append(
            {
                "id": str(row.get("id") or "").strip(),
                "label": str(row.get("label") or "").strip(),
                "public_url": str(row.get("public_url") or "").strip(),
                "storage_roots": storage_roots,
                "service_refs": service_refs,
            }
        )

    PROJECT_REGISTRY_CACHE = projects
    return projects


def fallback_host_project() -> dict[str, object] | None:
    for project in load_project_registry():
        if str(project.get("id") or "") == HOST_PROJECT_ID:
            return project
    return None


def project_context_for_path(path: Path | str) -> dict[str, object] | None:
    path_text = normalize_path_text(path)
    best_match: dict[str, object] | None = None
    best_match_len = -1

    for project in load_project_registry():
        for root in project.get("storage_roots", []):
            if not isinstance(root, str) or not root:
                continue
            if path_text == root or path_text.startswith(f"{root}/"):
                if len(root) > best_match_len:
                    best_match = project
                    best_match_len = len(root)

    target = best_match
    if target is None:
        host_project = fallback_host_project()
        if host_project and (
            path_text == "/tmp"
            or path_text.startswith("/tmp/")
            or path_text == "/var/tmp"
            or path_text.startswith("/var/tmp/")
            or path_text == "/var/log"
            or path_text.startswith("/var/log/")
            or path_text == "/var/cache"
            or path_text.startswith("/var/cache/")
            or "/.vscode-server/" in path_text
        ):
            target = host_project

    if target is None:
        return None

    out = {
        "project_id": str(target.get("id") or "").strip() or None,
        "project_label": str(target.get("label") or "").strip() or None,
        "project_url": str(target.get("public_url") or "").strip() or None,
        "service_refs": [ref for ref in target.get("service_refs", []) if isinstance(ref, str) and ref.strip()],
    }
    return out


def write_json(path: Path, payload: dict[str, object], mode: int = 0o600) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent)) as tmp:
        json.dump(payload, tmp, indent=2, sort_keys=True)
        tmp.write("\n")
        tmp_path = Path(tmp.name)
    os.chmod(tmp_path, mode)
    os.replace(tmp_path, path)


def walk_path_usage(path: Path) -> dict[str, int]:
    try:
        root_stat = path.stat(follow_symlinks=False)
    except OSError:
        return {"disk_bytes": 0, "apparent_bytes": 0, "file_count": 0}

    root_dev = root_stat.st_dev
    disk_bytes = getattr(root_stat, "st_blocks", 0) * 512 or root_stat.st_size
    apparent_bytes = root_stat.st_size
    file_count = 0

    if path.is_file() or path.is_symlink():
        return {
            "disk_bytes": disk_bytes,
            "apparent_bytes": apparent_bytes,
            "file_count": 1,
        }

    for dirpath, dirnames, filenames in os.walk(path, topdown=True, followlinks=False):
        current_dir = Path(dirpath)
        kept_dirs: list[str] = []

        for name in dirnames:
            child = current_dir / name
            try:
                if child.is_symlink():
                    continue
                st = child.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            disk_bytes += getattr(st, "st_blocks", 0) * 512 or st.st_size
            apparent_bytes += st.st_size
            kept_dirs.append(name)
        dirnames[:] = kept_dirs

        for name in filenames:
            child = current_dir / name
            try:
                st = child.lstat() if child.is_symlink() else child.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            disk_bytes += getattr(st, "st_blocks", 0) * 512 or st.st_size
            apparent_bytes += st.st_size
            file_count += 1

    return {
        "disk_bytes": disk_bytes,
        "apparent_bytes": apparent_bytes,
        "file_count": file_count,
    }


def path_disk_bytes(path: Path) -> int:
    return walk_path_usage(path)["disk_bytes"]


def find_matches(root: Path, pattern: str) -> list[tuple[int, float, Path]]:
    try:
        completed = subprocess.run(
            ["find", str(root), "-xdev", "-type", "f", "-path", pattern, "-printf", "%s\t%T@\t%p\n"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return []

    out: list[tuple[int, float, Path]] = []
    for line in completed.stdout.splitlines():
        raw = line.strip()
        if not raw:
            continue
        try:
            size_text, mtime_text, path_text = raw.split("\t", 2)
            out.append((int(size_text), float(mtime_text), Path(path_text)))
        except (TypeError, ValueError):
            continue
    return out


def measure_disk_available_bytes(path: str = "/") -> int:
    usage = shutil.disk_usage(path)
    return int(usage.free)


def journal_disk_usage_bytes() -> int | None:
    try:
        completed = subprocess.run(
            ["journalctl", "--disk-usage"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return None

    match = re.search(r"([0-9.]+)\s*([KMGTP]?B)", completed.stdout, re.IGNORECASE)
    if not match:
        return None

    amount = float(match.group(1))
    unit = match.group(2).upper()
    scale = {
        "B": 1,
        "KB": 1024,
        "MB": 1024 * 1024,
        "GB": 1024 * 1024 * 1024,
        "TB": 1024 * 1024 * 1024 * 1024,
        "PB": 1024 * 1024 * 1024 * 1024 * 1024,
    }.get(unit)
    if not scale:
        return None
    return int(amount * scale)


def execute_command_for(action: str, path_text: str) -> str:
    if action == "remove_path":
        return f"rm -rf {shlex.quote(path_text)}"
    if action == "apt_clean":
        return "apt-get clean"
    if action == "journal_vacuum":
        return f"journalctl --vacuum-size={JOURNAL_TARGET_BYTES}"
    return action or "cleanup"


def preview_command_for(path_text: str) -> str:
    return f"du -sh {shlex.quote(path_text)}"


def candidate(
    *,
    key: str,
    label: str,
    path: Path | str,
    bytes_value: int,
    action: str,
    kind: str,
    category: str,
    risk: str = "safe",
    explanation: str | None = None,
    regrows: bool = False,
    requires_stop: bool = False,
) -> dict[str, object]:
    path_obj = Path(path) if not isinstance(path, Path) else path
    path_text = str(path_obj)
    candidate_id = f"{action}:{path_obj.resolve() if path_obj.exists() else path_text}"
    project_context = project_context_for_path(path_obj)
    execute_command = execute_command_for(action, path_text)
    payload = {
        "id": candidate_id,
        "key": key,
        "label": label,
        "path": path_text,
        "bytes": max(0, int(bytes_value)),
        "action": action,
        "kind": kind,
        "category": category,
        "category_label": CATEGORY_META.get(category, {}).get("label", category.title()),
        "risk": risk,
        "risk_label": RISK_META.get(risk, {}).get("label", risk.title()),
        "requires_stop": requires_stop,
        "regrows": regrows,
        "explanation": explanation or "",
        "preview_command": preview_command_for(path_text),
        "execute_command": execute_command,
    }
    if project_context:
        payload.update(project_context)
    return payload


def dedupe_candidates(items: list[dict[str, object]]) -> list[dict[str, object]]:
    by_id: dict[str, dict[str, object]] = {}
    for item in items:
        raw_id = str(item.get("id") or "").strip()
        if not raw_id:
            continue
        prev = by_id.get(raw_id)
        if prev is None or int(item.get("bytes") or 0) > int(prev.get("bytes") or 0):
            by_id[raw_id] = item
    return list(by_id.values())


def scan_tmp_candidates() -> list[dict[str, object]]:
    min_age_seconds = TMP_MIN_AGE_HOURS * 3600
    out: list[dict[str, object]] = []
    for root in (Path("/tmp"), Path("/var/tmp")):
        if not root.is_dir():
            continue
        for child in root.iterdir():
            name = child.name
            if not (name in TMP_NAME_EXACT or any(name.startswith(prefix) for prefix in TMP_NAME_PREFIXES)):
                continue
            if age_seconds_for(child) < min_age_seconds:
                continue
            bytes_value = path_disk_bytes(child)
            if bytes_value <= 0:
                continue
            out.append(
                candidate(
                    key="tmp_stale",
                    label="Stale /tmp files",
                    path=child,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="garbage",
                    explanation=f"Temporary scratch files older than {TMP_MIN_AGE_HOURS}h.",
                )
            )
    return out


def find_paths(root: Path, pattern: str, path_type: str) -> list[Path]:
    try:
        completed = subprocess.run(
            ["find", str(root), "-xdev", "-type", path_type, "-path", pattern, "-print"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return []

    out: list[Path] = []
    for line in completed.stdout.splitlines():
        raw = line.strip()
        if raw:
            out.append(Path(raw))
    return out


def scan_next_cache_dirs() -> list[dict[str, object]]:
    out: list[dict[str, object]] = []
    for root in scan_roots():
        for path in find_paths(root, "*/.next/cache", "d"):
            bytes_value = path_disk_bytes(path)
            if bytes_value < NEXT_CACHE_MIN_BYTES:
                continue
            out.append(
                candidate(
                    key="next_cache",
                    label="Next.js build caches",
                    path=path,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="recycling",
                    explanation="Build cache data that will regenerate on the next install/build.",
                    regrows=True,
                )
            )
    return out


def scan_vscode_old_bins() -> list[dict[str, object]]:
    out: list[dict[str, object]] = []
    for home in home_roots():
        bin_root = home / ".vscode-server" / "bin"
        if not bin_root.is_dir():
            continue
        versions = [child for child in bin_root.iterdir() if child.is_dir() and not child.is_symlink()]
        if len(versions) <= 1:
            continue
        versions.sort(key=lambda item: item.stat(follow_symlinks=False).st_mtime, reverse=True)
        for old in versions[1:]:
            bytes_value = path_disk_bytes(old)
            if bytes_value <= 0:
                continue
            out.append(
                candidate(
                    key="vscode_old",
                    label="Old VS Code server versions",
                    path=old,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="recycling",
                    explanation="Older VS Code remote-server builds that can be reinstalled if needed.",
                    regrows=True,
                )
            )
    return out


def extension_family(name: str) -> str | None:
    match = EXTENSION_VERSION_RE.match(name)
    if not match:
        return None
    return str(match.group("base") or "").strip() or None


def scan_vscode_old_extensions() -> list[dict[str, object]]:
    out: list[dict[str, object]] = []
    for home in home_roots():
        ext_root = home / ".vscode-server" / "extensions"
        if not ext_root.is_dir():
            continue
        grouped: dict[str, list[Path]] = {}
        for child in ext_root.iterdir():
            if not child.is_dir() or child.is_symlink():
                continue
            family = extension_family(child.name)
            if not family:
                continue
            grouped.setdefault(family, []).append(child)
        for _, versions in grouped.items():
            if len(versions) <= 1:
                continue
            versions.sort(key=lambda item: item.stat(follow_symlinks=False).st_mtime, reverse=True)
            for old in versions[1:]:
                bytes_value = path_disk_bytes(old)
                if bytes_value <= 0:
                    continue
                out.append(
                    candidate(
                        key="vscode_extensions_old",
                        label="Old VS Code extension versions",
                        path=old,
                        bytes_value=bytes_value,
                        action="remove_path",
                        kind="path",
                        category="recycling",
                        explanation="Superseded VS Code extensions; latest version remains installed.",
                        regrows=True,
                    )
                )
    return out


def scan_vsix_cache() -> list[dict[str, object]]:
    min_age_seconds = VSIX_MIN_AGE_HOURS * 3600
    out: list[dict[str, object]] = []
    for home in home_roots():
        cache_root = home / ".vscode-server" / "data" / "CachedExtensionVSIXs"
        if not cache_root.is_dir():
            continue
        for child in cache_root.iterdir():
            if age_seconds_for(child) < min_age_seconds:
                continue
            bytes_value = path_disk_bytes(child)
            if bytes_value <= 0:
                continue
            out.append(
                candidate(
                    key="vscode_cache",
                    label="VS Code cached VSIX downloads",
                    path=child,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="recycling",
                    explanation=f"Cached extension downloads older than {VSIX_MIN_AGE_HOURS}h.",
                    regrows=True,
                )
            )
    return out


def scan_package_caches() -> list[dict[str, object]]:
    out: list[dict[str, object]] = []
    for home in home_roots():
        for suffix in PACKAGE_CACHE_SUFFIXES:
            target = home / suffix
            if not target.exists():
                continue
            bytes_value = path_disk_bytes(target)
            if bytes_value < PACKAGE_CACHE_MIN_BYTES:
                continue
            out.append(
                candidate(
                    key="pkg_cache",
                    label="Package manager caches",
                    path=target,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="recycling",
                    explanation="Package caches can be re-downloaded when the tool needs them again.",
                    regrows=True,
                )
            )
    return out


def scan_apt_cache() -> list[dict[str, object]]:
    apt_root = Path("/var/cache/apt/archives")
    if not apt_root.exists():
        return []
    bytes_value = path_disk_bytes(apt_root)
    if bytes_value < APT_CACHE_MIN_BYTES:
        return []
    return [
        candidate(
            key="apt_cache",
            label="APT package cache",
            path=apt_root,
            bytes_value=bytes_value,
            action="apt_clean",
            kind="command",
            category="recycling",
            explanation="APT archives can be re-fetched from package repositories.",
            regrows=True,
        )
    ]


def scan_journal_excess() -> list[dict[str, object]]:
    usage = journal_disk_usage_bytes()
    if usage is None or usage <= JOURNAL_TARGET_BYTES:
        return []
    return [
        candidate(
            key="journald_excess",
            label="Journal logs above cap",
            path=Path("/var/log/journal"),
            bytes_value=max(0, usage - JOURNAL_TARGET_BYTES),
            action="journal_vacuum",
            kind="command",
            category="garbage",
            explanation="Rotated journal history above the configured cap.",
            regrows=True,
        )
    ]


def scan_backup_retention() -> list[dict[str, object]]:
    out: list[dict[str, object]] = []
    suffixes = (".tgz", ".tar.gz", ".zip")
    for root in backup_roots():
        archives = [
            child
            for child in root.iterdir()
            if child.is_file() and any(child.name.endswith(suffix) for suffix in suffixes)
        ]
        if len(archives) <= BACKUP_KEEP:
            continue
        archives.sort(key=lambda item: item.stat(follow_symlinks=False).st_mtime, reverse=True)
        for old in archives[BACKUP_KEEP:]:
            bytes_value = path_disk_bytes(old)
            if bytes_value <= 0:
                continue
            out.append(
                candidate(
                    key="backup_prune",
                    label="Backup retention pruning",
                    path=old,
                    bytes_value=bytes_value,
                    action="remove_path",
                    kind="path",
                    category="garbage",
                    explanation=f"Backup archive older than the keep window ({BACKUP_KEEP} newest kept).",
                )
            )
    return out


def collect_candidates() -> list[dict[str, object]]:
    return dedupe_candidates(
        scan_tmp_candidates()
        + scan_next_cache_dirs()
        + scan_vscode_old_bins()
        + scan_vscode_old_extensions()
        + scan_vsix_cache()
        + scan_package_caches()
        + scan_apt_cache()
        + scan_journal_excess()
        + scan_backup_retention()
    )


def safe_candidates_for_profile(candidates: list[dict[str, object]], profile: str) -> list[dict[str, object]]:
    safe = [item for item in candidates if str(item.get("risk") or "safe") == "safe"]
    if profile in {"garbage", "recycling"}:
        return [item for item in safe if str(item.get("category") or "") == profile]
    return safe


def summarize_candidates(
    candidates: list[dict[str, object]], last_cleanup_result: dict[str, object] | None
) -> dict[str, object]:
    measured_at = iso_utc_now()
    buckets: dict[str, dict[str, object]] = {}
    categories: dict[str, dict[str, object]] = {}
    risks: dict[str, dict[str, object]] = {}
    top_paths: list[dict[str, object]] = []
    candidate_rows: list[dict[str, object]] = []

    for item in candidates:
        key = str(item["key"])
        label = str(item["label"])
        bytes_value = int(item["bytes"])
        category = str(item.get("category") or "garbage")
        risk = str(item.get("risk") or "safe")
        bucket = buckets.setdefault(
            key,
            {
                "key": key,
                "label": label,
                "bytes": 0,
                "count": 0,
            },
        )
        bucket["bytes"] = int(bucket["bytes"]) + bytes_value
        bucket["count"] = int(bucket["count"]) + 1
        category_row = categories.setdefault(
            category,
            {
                "key": category,
                "label": CATEGORY_META.get(category, {}).get("label", category.title()),
                "description": CATEGORY_META.get(category, {}).get("description", ""),
                "bytes": 0,
                "count": 0,
            },
        )
        category_row["bytes"] = int(category_row["bytes"]) + bytes_value
        category_row["count"] = int(category_row["count"]) + 1
        risk_row = risks.setdefault(
            risk,
            {
                "key": risk,
                "label": RISK_META.get(risk, {}).get("label", risk.title()),
                "bytes": 0,
                "count": 0,
            },
        )
        risk_row["bytes"] = int(risk_row["bytes"]) + bytes_value
        risk_row["count"] = int(risk_row["count"]) + 1
        top_paths.append(
            {
                "path": str(item["path"]),
                "bytes": bytes_value,
                "bucket": key,
            }
        )
        candidate_rows.append(item)

    bucket_rows = sorted(
        buckets.values(),
        key=lambda row: (-int(row["bytes"]), str(row["label"])),
    )
    category_rows = sorted(
        categories.values(),
        key=lambda row: (-int(row["bytes"]), str(row["label"])),
    )
    risk_rows = sorted(
        risks.values(),
        key=lambda row: (-int(row["bytes"]), str(row["label"])),
    )
    top_paths.sort(key=lambda row: (-int(row["bytes"]), str(row["path"])))
    candidate_rows.sort(key=lambda row: (-int(row["bytes"]), str(row["label"]), str(row["path"])))

    reclaimable_bytes_total = sum(int(item["bytes"]) for item in candidates)
    safe_reclaimable_bytes = sum(int(item["bytes"]) for item in candidates if str(item.get("risk") or "safe") == "safe")
    garbage_reclaimable_bytes = sum(int(item["bytes"]) for item in candidates if str(item.get("category") or "") == "garbage")
    rebuildable_bytes = sum(int(item["bytes"]) for item in candidates if str(item.get("category") or "") == "recycling")
    guided_reclaimable_bytes = sum(int(item["bytes"]) for item in candidates if str(item.get("risk") or "") == "guided")
    blocked_reclaimable_bytes = sum(
        int(item["bytes"]) for item in candidates if str(item.get("risk") or "") in {"dangerous", "blocked"}
    )

    return {
        "schema_version": SCHEMA_VERSION,
        "measured_at": measured_at,
        "ttl_seconds": TTL_SECONDS,
        "reclaimable_bytes_total": reclaimable_bytes_total,
        "safe_reclaimable_bytes": safe_reclaimable_bytes,
        "garbage_reclaimable_bytes": garbage_reclaimable_bytes,
        "rebuildable_bytes": rebuildable_bytes,
        "guided_reclaimable_bytes": guided_reclaimable_bytes,
        "blocked_reclaimable_bytes": blocked_reclaimable_bytes,
        "category_totals": category_rows,
        "risk_totals": risk_rows,
        "candidates": candidate_rows,
        "buckets": bucket_rows,
        "top_paths": top_paths[:TOP_PATHS_LIMIT],
        "running_cleanup": RUNNING_JSON.exists(),
        "last_cleanup_result": last_cleanup_result,
    }


def cache_is_fresh(snapshot: dict[str, object]) -> bool:
    measured_at = parse_iso(snapshot.get("measured_at"))
    if measured_at is None:
        return False
    age_seconds = (datetime.now(timezone.utc) - measured_at).total_seconds()
    return age_seconds < TTL_SECONDS


def merge_into_last(snapshot: dict[str, object]) -> None:
    if not LAST_JSON.exists():
        log(f"warn: missing {LAST_JSON}; skipping merge")
        return
    payload = load_json(LAST_JSON)
    if payload is None:
        log(f"warn: unable to parse {LAST_JSON}; skipping merge")
        return
    payload["garbage_estimate"] = snapshot
    write_json(LAST_JSON, payload, 0o644)


def publish_public() -> None:
    publish_path = Path("/usr/local/bin/vps-sentry-publish")
    if not publish_path.exists():
        log("warn: /usr/local/bin/vps-sentry-publish missing; public status not refreshed")
        return
    try:
        subprocess.run([str(publish_path)], check=True, capture_output=True, text=True)
    except (OSError, subprocess.CalledProcessError) as exc:
        log(f"warn: publish refresh failed: {exc}")


def publish_snapshot(snapshot: dict[str, object]) -> None:
    write_json(CACHE_JSON, snapshot, 0o600)
    merge_into_last(snapshot)
    publish_public()


def estimate_snapshot(force: bool) -> dict[str, object]:
    last_cleanup_result = load_json(LAST_CLEANUP_JSON)
    cached = load_json(CACHE_JSON)
    if not force and cached and cache_is_fresh(cached):
        cached["running_cleanup"] = RUNNING_JSON.exists()
        cached["last_cleanup_result"] = last_cleanup_result
        return cached

    snapshot = summarize_candidates(collect_candidates(), last_cleanup_result)
    write_json(CACHE_JSON, snapshot, 0o600)
    return snapshot


def run_cleanup_command(args: list[str]) -> tuple[bool, str]:
    try:
        completed = subprocess.run(args, check=True, capture_output=True, text=True)
        return True, completed.stdout.strip()
    except (OSError, subprocess.CalledProcessError) as exc:
        return False, str(exc)


def remove_path(target: Path) -> tuple[bool, str]:
    try:
        if target.is_symlink() or target.is_file():
            target.unlink(missing_ok=True)
        elif target.is_dir():
            shutil.rmtree(target, ignore_errors=False)
        else:
            target.unlink(missing_ok=True)
        return True, ""
    except FileNotFoundError:
        return True, ""
    except Exception as exc:
        return False, str(exc)


def apply_candidate(item: dict[str, object]) -> tuple[bool, str]:
    action = str(item.get("action") or "")
    target = Path(str(item.get("path") or ""))
    if action == "remove_path":
        return remove_path(target)
    if action == "apt_clean":
        return run_cleanup_command(["apt-get", "clean"])
    if action == "journal_vacuum":
        return run_cleanup_command(["journalctl", f"--vacuum-size={JOURNAL_TARGET_BYTES}"])
    return False, f"unsupported action: {action}"


def cleanup_result_for_error(message: str, profile: str = "safe") -> dict[str, object]:
    return {
        "ok": False,
        "profile": profile,
        "started_at": iso_utc_now(),
        "finished_at": iso_utc_now(),
        "freed_bytes_estimated": 0,
        "freed_bytes_actual": 0,
        "deleted_count": 0,
        "buckets": [],
        "errors": [message],
    }


def trim_recent_lines(lines: list[str]) -> list[str]:
    out = [line.strip() for line in lines if isinstance(line, str) and line.strip()]
    return out[-PROGRESS_RECENT_LINES_LIMIT:]


def command_preview(item: dict[str, object]) -> str:
    action = str(item.get("action") or "").strip()
    path = str(item.get("path") or "").strip()
    return execute_command_for(action, path)


def estimate_eta_seconds(started_at: str, completed_steps: int | None, total_steps: int | None) -> int | None:
    if not completed_steps or not total_steps or completed_steps <= 0 or total_steps <= completed_steps:
        return None
    started = parse_iso(started_at)
    if started is None:
        return None
    elapsed_seconds = max(1.0, (datetime.now(timezone.utc) - started).total_seconds())
    remaining_steps = max(0, total_steps - completed_steps)
    if remaining_steps <= 0:
        return None
    return max(1, int(round((elapsed_seconds / completed_steps) * remaining_steps)))


def build_running_progress(
    *,
    started_at: str,
    phase: str,
    current_label: str,
    current_target: str | None,
    current_command: str | None,
    completed_steps: int | None,
    total_steps: int | None,
    errors_count: int,
    recent_lines: list[str],
) -> dict[str, object]:
    eta_seconds = estimate_eta_seconds(started_at, completed_steps, total_steps)
    return {
        "started_at": started_at,
        "updated_at": iso_utc_now(),
        "phase": phase,
        "current_label": current_label,
        "current_target": current_target,
        "current_command": current_command,
        "completed_steps": completed_steps,
        "total_steps": total_steps,
        "errors_count": errors_count,
        "eta_seconds": eta_seconds,
        "recent_lines": trim_recent_lines(recent_lines),
    }


def write_running_progress(
    progress: dict[str, object],
    last_cleanup_result: dict[str, object] | None,
    *,
    publish: bool,
) -> None:
    write_json(RUNNING_JSON, progress, 0o600)
    if publish:
        publish_snapshot(running_snapshot(last_cleanup_result, progress))


def running_snapshot(
    last_cleanup_result: dict[str, object] | None,
    progress: dict[str, object] | None = None,
) -> dict[str, object]:
    cached = load_json(CACHE_JSON) or {}
    snapshot = dict(cached)
    snapshot.setdefault("schema_version", SCHEMA_VERSION)
    snapshot.setdefault("measured_at", iso_utc_now())
    snapshot.setdefault("ttl_seconds", TTL_SECONDS)
    snapshot.setdefault("reclaimable_bytes_total", 0)
    snapshot.setdefault("safe_reclaimable_bytes", 0)
    snapshot.setdefault("garbage_reclaimable_bytes", 0)
    snapshot.setdefault("rebuildable_bytes", 0)
    snapshot.setdefault("guided_reclaimable_bytes", 0)
    snapshot.setdefault("blocked_reclaimable_bytes", 0)
    snapshot.setdefault("category_totals", [])
    snapshot.setdefault("risk_totals", [])
    snapshot.setdefault("candidates", [])
    snapshot.setdefault("buckets", [])
    snapshot.setdefault("top_paths", [])
    snapshot["running_cleanup"] = True
    snapshot["last_cleanup_result"] = last_cleanup_result
    snapshot["cleanup_progress"] = progress
    return snapshot


def run_reclaim(profile: str) -> tuple[int, dict[str, object]]:
    started_at = iso_utc_now()
    profile_meta = PROFILE_META.get(profile, PROFILE_META["safe"])
    recent_lines = [f"$ scan {profile_meta['label']} candidates"]
    write_running_progress(
        build_running_progress(
            started_at=started_at,
            phase="scanning",
            current_label=str(profile_meta["scan_label"]),
            current_target=None,
            current_command=f"scan {profile_meta['label']} candidates",
            completed_steps=0,
            total_steps=None,
            errors_count=0,
            recent_lines=recent_lines,
        ),
        load_json(LAST_CLEANUP_JSON),
        publish=True,
    )

    before_available = measure_disk_available_bytes("/")
    all_candidates = collect_candidates()
    candidates = safe_candidates_for_profile(all_candidates, profile)
    total_steps = len(candidates) + 1
    bucket_rows: dict[str, dict[str, object]] = {}
    errors: list[str] = []
    deleted_count = 0
    freed_bytes_estimated = 0
    processed_steps = 0

    if not candidates:
        recent_lines.append(str(profile_meta["empty_label"]))

    for item in candidates:
        key = str(item["key"])
        label = str(item["label"])
        bytes_value = int(item["bytes"])
        command_text = command_preview(item)
        recent_lines.append(f"$ {command_text}")
        write_running_progress(
            build_running_progress(
                started_at=started_at,
                phase="reclaiming",
                current_label=label,
                current_target=str(item.get("path") or "") or None,
                current_command=command_text,
                completed_steps=processed_steps,
                total_steps=total_steps,
                errors_count=len(errors),
                recent_lines=recent_lines,
            ),
            load_json(LAST_CLEANUP_JSON),
            publish=False,
        )

        bucket = bucket_rows.setdefault(
            key,
            {
                "key": key,
                "label": label,
                "estimated_bytes": 0,
                "deleted_count": 0,
            },
        )
        bucket["estimated_bytes"] = int(bucket["estimated_bytes"]) + bytes_value
        freed_bytes_estimated += bytes_value

        ok, detail = apply_candidate(item)
        if ok:
            deleted_count += 1
            bucket["deleted_count"] = int(bucket["deleted_count"]) + 1
            recent_lines.append(f"deleted {label} ({bytes_value}B)")
        elif detail:
            errors.append(f"{item['path']}: {detail}")
            recent_lines.append(f"error: {detail}")
        processed_steps += 1

    recent_lines.append("$ rescan reclaimable space")
    write_running_progress(
        build_running_progress(
            started_at=started_at,
            phase="rescanning",
            current_label="Re-scanning reclaimable space",
            current_target=None,
            current_command="scan safe garbage candidates",
            completed_steps=processed_steps,
            total_steps=total_steps,
            errors_count=len(errors),
            recent_lines=recent_lines,
        ),
        load_json(LAST_CLEANUP_JSON),
        publish=False,
    )

    after_available = measure_disk_available_bytes("/")
    finished_at = iso_utc_now()
    freed_bytes_actual = max(0, after_available - before_available)

    result = {
        "ok": len(errors) == 0,
        "profile": profile,
        "started_at": started_at,
        "finished_at": finished_at,
        "freed_bytes_estimated": freed_bytes_estimated,
        "freed_bytes_actual": freed_bytes_actual,
        "deleted_count": deleted_count,
        "buckets": sorted(bucket_rows.values(), key=lambda row: (-int(row["estimated_bytes"]), str(row["label"]))),
        "errors": errors,
    }

    write_json(LAST_CLEANUP_JSON, result, 0o600)
    try:
        RUNNING_JSON.unlink(missing_ok=True)
    except Exception:
        pass

    snapshot = summarize_candidates(collect_candidates(), result)
    publish_snapshot(snapshot)
    result["estimate"] = snapshot
    return (0 if result["ok"] else 1), result


def acquire_lock(nonblocking: bool):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    handle = LOCK_FILE.open("a+")
    import fcntl

    flags = fcntl.LOCK_EX | (fcntl.LOCK_NB if nonblocking else 0)
    fcntl.flock(handle.fileno(), flags)
    return handle


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Estimate or reclaim safe garbage on the VPS.")
    parser.add_argument("--force", action="store_true", help="Ignore cache TTL and rescan now.")
    parser.add_argument("--json", action="store_true", help="Print resulting JSON payload to stdout.")
    parser.add_argument("--reclaim", action="store_true", help="Delete matched safe garbage and refresh the estimate.")
    parser.add_argument(
        "--profile",
        choices=sorted(PROFILE_META.keys()),
        default="safe",
        help="Restrict reclaim to all safe candidates, only Garbage Dump, or only Recycling Center.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    try:
        lock_handle = acquire_lock(nonblocking=args.reclaim)
    except BlockingIOError:
        payload = cleanup_result_for_error("garbage cleanup already running", profile=args.profile)
        if args.json:
            json.dump(payload, sys.stdout, indent=2, sort_keys=True)
            sys.stdout.write("\n")
        else:
            log("cleanup already running")
        return 1

    with lock_handle:
        if args.reclaim:
            status, payload = run_reclaim(args.profile)
        else:
            payload = estimate_snapshot(force=args.force)
            merge_into_last(payload)
            status = 0

        if args.json:
            json.dump(payload, sys.stdout, indent=2, sort_keys=True)
            sys.stdout.write("\n")

        return status


if __name__ == "__main__":
    raise SystemExit(main())
