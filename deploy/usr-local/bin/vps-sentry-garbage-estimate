STATE_DIR = Path(os.environ.get("VPS_SENTRY_STATE_DIR", "/var/lib/vps-sentry"))
LAST_JSON = STATE_DIR / "last.json"
CACHE_JSON = STATE_DIR / "garbage-estimate.json"
LAST_CLEANUP_JSON = STATE_DIR / "garbage-last-cleanup.json"
LOCK_FILE = STATE_DIR / ".garbage.lock"
RUNNING_JSON = STATE_DIR / "garbage-running-cleanup.json"
TTL_SECONDS = max(60, int(os.environ.get("VPS_SENTRY_GARBAGE_TTL_SECONDS", "600")))
TMP_MIN_AGE_HOURS = max(1, int(os.environ.get("VPS_SENTRY_GARBAGE_TMP_MIN_AGE_HOURS", "24")))
NEXT_OLDPACK_MIN_AGE_HOURS = max(1, int(os.environ.get("VPS_SENTRY_GARBAGE_NEXT_OLDPACK_MIN_AGE_HOURS", "2")))
VSIX_MIN_AGE_HOURS = max(1, int(os.environ.get("VPS_SENTRY_GARBAGE_VSIX_MIN_AGE_HOURS", "6")))
PACKAGE_CACHE_MIN_BYTES = max(
    0, int(os.environ.get("VPS_SENTRY_GARBAGE_PACKAGE_CACHE_MIN_BYTES", str(50 * 1024 * 1024)))
)
NEXT_CACHE_MIN_BYTES = max(
    0, int(os.environ.get("VPS_SENTRY_GARBAGE_NEXT_CACHE_MIN_BYTES", str(25 * 1024 * 1024)))
)
APT_CACHE_MIN_BYTES = max(
    0, int(os.environ.get("VPS_SENTRY_GARBAGE_APT_CACHE_MIN_BYTES", str(50 * 1024 * 1024)))
)
JOURNAL_TARGET_BYTES = max(
    32 * 1024 * 1024,
    int(os.environ.get("VPS_SENTRY_GARBAGE_JOURNAL_TARGET_BYTES", str(200 * 1024 * 1024))),
)
BACKUP_KEEP = max(1, int(os.environ.get("VPS_SENTRY_GARBAGE_BACKUP_KEEP", "5")))
TOP_PATHS_LIMIT = max(3, int(os.environ.get("VPS_SENTRY_GARBAGE_TOP_PATHS_LIMIT", "8")))
PROGRESS_RECENT_LINES_LIMIT = max(3, int(os.environ.get("VPS_SENTRY_GARBAGE_PROGRESS_LINES", "6")))
PROJECTS_JSON = Path(os.environ.get("VPS_SENTRY_PROJECTS_JSON", "/etc/vps-sentry-projects.json"))
HOST_PROJECT_ID = os.environ.get("VPS_SENTRY_GARBAGE_HOST_PROJECT_ID", "vps-host")
SCHEMA_VERSION = 2

