PROJECT_GROWTH_FAIL_BYTES = max(PROJECT_GROWTH_WARN_BYTES, int(os.environ.get("VPS_SENTRY_PROJECT_GROWTH_FAIL_BYTES", str(1024 * 1024 * 1024))))
