def log(message: str) -> None:
    print(f"[VPS-PROJECT-STORAGE] {message}", file=sys.stderr)


def iso_utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parse_iso(ts: object) -> datetime | None:
    if not isinstance(ts, str) or not ts.strip():
        return None
    raw = ts.strip()
    try:
        if raw.endswith("Z"):
            raw = raw[:-1] + "+00:00"
        return datetime.fromisoformat(raw)
    except ValueError:
        return None


def fmt_bytes(value: int | float | None) -> str:
    if value is None:
        return "—"
    units = ["B", "KB", "MB", "GB", "TB"]
    amount = float(abs(value))
    unit_index = 0
    while amount >= 1024 and unit_index < len(units) - 1:
        amount /= 1024
        unit_index += 1
    decimals = 0 if amount >= 10 or unit_index == 0 else 1
    prefix = "-" if value < 0 else ""
    return f"{prefix}{amount:.{decimals}f}{units[unit_index]}"


def age_label(previous_ts: object, current_ts: object) -> str | None:
    previous = parse_iso(previous_ts)
    current = parse_iso(current_ts)
    if previous is None or current is None:
        return None
    delta_seconds = int((current - previous).total_seconds())
    if delta_seconds <= 0:
        return None
    hours = delta_seconds // 3600
    minutes = (delta_seconds % 3600) // 60
    if hours > 0:
        return f"{hours}h {minutes}m"
    return f"{max(1, minutes)}m"


def parse_csv_paths(raw: str | None) -> list[Path]:
    if not raw:
        return []
    out: list[Path] = []
    for part in raw.split(","):
        text = part.strip()
        if text:
            out.append(Path(text))
    return out


def run_bytes_command(args: list[str]) -> int:
    completed = subprocess.run(args, check=True, capture_output=True, text=True)
    first = completed.stdout.strip().splitlines()[0] if completed.stdout.strip() else ""
    number = first.split(maxsplit=1)[0] if first else ""
    return int(number)


def decode_mountinfo_field(value: str) -> str:
    return re.sub(r"\\([0-7]{3})", lambda match: chr(int(match.group(1), 8)), value)


def resolved_path(path: Path) -> Path:
    try:
        return path.resolve()
    except Exception:
        return Path(os.path.abspath(str(path)))


def path_is_inside(path: Path, root: Path) -> bool:
    if path == root:
        return True
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def mountinfo_for_path(path: Path) -> dict[str, str] | None:
    target = resolved_path(path)
    best: dict[str, str] | None = None
    best_len = -1

    try:
        lines = Path("/proc/self/mountinfo").read_text().splitlines()
    except OSError:
        return None

    for line in lines:
        parts = line.split()
        if len(parts) < 10 or "-" not in parts:
            continue
        separator_index = parts.index("-")
        if separator_index + 2 >= len(parts):
            continue

        major_minor = parts[2]
        mount_point = resolved_path(Path(decode_mountinfo_field(parts[4])))
        if not path_is_inside(target, mount_point):
            continue

        mount_len = len(str(mount_point))
        if mount_len <= best_len:
            continue

        best_len = mount_len
        best = {
            "major_minor": major_minor,
            "mount_point": str(mount_point),
            "filesystem_type": decode_mountinfo_field(parts[separator_index + 1]),
            "device_source": decode_mountinfo_field(parts[separator_index + 2]),
        }

    return best


def block_device_size_bytes(major_minor: str | None) -> int | None:
    if not major_minor:
        return None
    try:
        sectors = int((Path("/sys/dev/block") / major_minor / "size").read_text().strip())
    except (OSError, ValueError):
        return None
    if sectors <= 0:
        return None
    return sectors * 512


def filesystem_resize_gap_threshold(device_size_bytes: int) -> int:
    return max(FILESYSTEM_RESIZE_GAP_MIN_BYTES, int(device_size_bytes * FILESYSTEM_RESIZE_GAP_MIN_RATIO))


def count_files(root: Path) -> int:
    try:
        completed = subprocess.run(
            ["find", str(root), "-xdev", "-type", "f"],
            check=True,
            capture_output=True,
            text=True,
        )
        return sum(1 for line in completed.stdout.splitlines() if line.strip())
    except subprocess.CalledProcessError:
        return walk_path_usage(root)["file_count"]


def walk_path_usage(path: Path) -> dict[str, int]:
    try:
        root_stat = path.stat(follow_symlinks=False)
    except OSError:
        return {
            "disk_bytes": 0,
            "apparent_bytes": 0,
            "file_count": 0,
        }

    root_dev = root_stat.st_dev
    disk_bytes = getattr(root_stat, "st_blocks", 0) * 512 or root_stat.st_size
    apparent_bytes = root_stat.st_size
    file_count = 0

    if path.is_file():
        return {
            "disk_bytes": disk_bytes,
            "apparent_bytes": apparent_bytes,
            "file_count": 1,
        }

    for dirpath, dirnames, filenames in os.walk(path, topdown=True, followlinks=False):
        current_dir = Path(dirpath)
        kept: list[str] = []
        for name in dirnames:
            child = current_dir / name
            try:
                if child.is_symlink():
                    continue
                st = child.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            disk_bytes += getattr(st, "st_blocks", 0) * 512 or st.st_size
            apparent_bytes += st.st_size
            kept.append(name)
        dirnames[:] = kept

        for name in filenames:
            child = current_dir / name
            try:
                if child.is_symlink():
                    st = child.lstat()
                else:
                    st = child.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            disk_bytes += getattr(st, "st_blocks", 0) * 512 or st.st_size
            apparent_bytes += st.st_size
            file_count += 1

    return {
        "disk_bytes": disk_bytes,
        "apparent_bytes": apparent_bytes,
        "file_count": file_count,
    }


def largest_dirs(root: Path, root_label: str) -> list[dict[str, object]]:
    try:
        completed = subprocess.run(
            ["du", "-x", "-B1", "-d", str(TOP_DIR_DEPTH), str(root)],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError:
        return []
    entries: list[dict[str, object]] = []
    for line in completed.stdout.splitlines():
        raw = line.strip()
        if not raw:
            continue
        try:
            size_text, path_text = raw.split(maxsplit=1)
            size = int(size_text)
        except (ValueError, IndexError):
            continue
        try:
            rel = Path(path_text).resolve().relative_to(root.resolve())
            rel_label = rel.as_posix()
        except Exception:
            continue
        if rel_label in {".", ""}:
            continue
        entries.append(
            {
                "label": f"{root_label}/{rel_label}",
                "disk_bytes": size,
            }
        )
    entries.sort(key=lambda item: int(item.get("disk_bytes", 0)), reverse=True)
    return entries[:TOP_DIR_LIMIT]


def bucket_template(bucket_id: str) -> dict[str, object]:
    return {
        "label": BUCKET_LABELS[bucket_id],
        "disk_bytes": 0,
        "apparent_bytes": 0,
        "file_count": 0,
        "match_count": 0,
    }


def unique_paths(paths: list[Path]) -> list[Path]:
    seen: set[str] = set()
    unique: list[Path] = []
    for path in paths:
        try:
            key = str(path.resolve())
        except Exception:
            key = str(path)
        if key in seen:
            continue
        seen.add(key)
        unique.append(path)
    return unique


def load_config() -> dict[str, object]:
    if not PROJECTS_FILE.exists():
        return {}
    try:
        payload = json.loads(PROJECTS_FILE.read_text())
        return payload if isinstance(payload, dict) else {}
    except Exception as exc:
        log(f"warn: failed to parse {PROJECTS_FILE}: {exc}")
        return {}


def previous_mounted_filesystem(
    previous_snapshot: dict[str, object] | None,
    *,
    fs_id: str | None = None,
    path: str | None = None,
) -> dict[str, object] | None:
    if not isinstance(previous_snapshot, dict):
        return None

    mounted = previous_snapshot.get("mounted_filesystems")
    if not isinstance(mounted, list):
        return None

    normalized_id = fs_id.strip() if isinstance(fs_id, str) and fs_id.strip() else None
    normalized_path = path.strip() if isinstance(path, str) and path.strip() else None

    for entry in mounted:
        if not isinstance(entry, dict):
            continue
        entry_id = str(entry.get("id") or "").strip() or None
        entry_path = str(entry.get("path") or "").strip() or None
        if normalized_id and entry_id == normalized_id:
            return entry
        if normalized_path and entry_path == normalized_path:
            return entry

    return None


def measure_filesystem(
    path: Path,
    *,
    fs_id: str | None = None,
    label: str | None = None,
    previous_total_bytes: int | None = None,
) -> dict[str, object]:
    exists = path.exists()
    total_bytes = 0
    available_bytes = 0
    used_bytes = 0
    used_percent = None
    level = "warn" if not exists else "ok"
    mount_info: dict[str, str] | None = None
    device_size_bytes: int | None = None

    if exists:
        try:
            vfs = os.statvfs(str(path))
            block_size = int(vfs.f_frsize or vfs.f_bsize or 0)
            total_bytes = int(vfs.f_blocks * block_size) if block_size > 0 else 0
            available_bytes = int(vfs.f_bavail * block_size) if block_size > 0 else 0
            used_bytes = max(0, total_bytes - available_bytes)
            used_percent = round((used_bytes / total_bytes) * 100, 1) if total_bytes > 0 else None

            if isinstance(used_percent, float) and used_percent >= HOST_DISK_FAIL_PCT:
                level = "critical"
            elif isinstance(used_percent, float) and used_percent >= HOST_DISK_WARN_PCT:
                level = "warn"
            else:
                level = "ok"
            mount_info = mountinfo_for_path(path)
            if mount_info is not None:
                device_size_bytes = block_device_size_bytes(mount_info.get("major_minor"))
        except OSError:
            exists = False
            level = "warn"

    payload: dict[str, object] = {
        "path": str(path),
        "exists": exists,
        "measured_at": iso_utc_now(),
        "total_bytes": total_bytes,
        "used_bytes": used_bytes,
        "available_bytes": available_bytes,
        "used_percent": used_percent,
        "warn_percent": HOST_DISK_WARN_PCT,
        "fail_percent": HOST_DISK_FAIL_PCT,
        "level": level,
    }
    if fs_id is not None:
        payload["id"] = fs_id
    if label is not None:
        payload["label"] = label
    if mount_info is not None:
        payload["device_source"] = mount_info.get("device_source")
        payload["filesystem_type"] = mount_info.get("filesystem_type")
        payload["mount_point"] = mount_info.get("mount_point")
    if isinstance(device_size_bytes, int) and device_size_bytes > 0:
        payload["device_size_bytes"] = device_size_bytes
        gap_bytes = device_size_bytes - total_bytes
        if total_bytes > 0 and gap_bytes > filesystem_resize_gap_threshold(device_size_bytes):
            payload["filesystem_gap_bytes"] = gap_bytes
            payload["filesystem_resize_pending"] = True
    if isinstance(previous_total_bytes, int) and previous_total_bytes > 0 and total_bytes != previous_total_bytes:
        payload["previous_total_bytes"] = previous_total_bytes
        payload["capacity_changed_bytes"] = total_bytes - previous_total_bytes
        payload["capacity_change_direction"] = "expanded" if total_bytes > previous_total_bytes else "shrunk"
    return payload


def measure_host_filesystem() -> dict[str, object]:
    path = HOST_FILESYSTEM_PATH if HOST_FILESYSTEM_PATH.exists() else Path("/")
    return measure_filesystem(path)


def load_projects(config: dict[str, object] | None = None) -> list[dict[str, object]]:
    payload = config if isinstance(config, dict) else load_config()
    projects = payload.get("projects")
    if not isinstance(projects, list):
        return []
    return [project for project in projects if isinstance(project, dict)]


def load_mounted_host_filesystems(config: dict[str, object] | None = None) -> list[dict[str, str]]:
    payload = config if isinstance(config, dict) else load_config()
    raw_filesystems = payload.get("host_filesystems")
    if not isinstance(raw_filesystems, list):
        return []

    filesystems: list[dict[str, str]] = []
    for index, raw_entry in enumerate(raw_filesystems):
        if isinstance(raw_entry, str):
            path = raw_entry.strip()
            if not path:
                continue
            filesystems.append(
                {
                    "id": f"host-fs-{index + 1}",
                    "label": Path(path).name or path,
                    "path": path,
                }
            )
            continue

        if not isinstance(raw_entry, dict):
            continue

        path = str(raw_entry.get("path") or "").strip()
        if not path:
            continue

        fs_id = str(raw_entry.get("id") or "").strip() or f"host-fs-{index + 1}"
        label = str(raw_entry.get("label") or "").strip() or (Path(path).name or path)

        filesystems.append(
            {
                "id": fs_id,
                "label": label,
                "path": path,
            }
        )

    return filesystems


def measure_mounted_filesystems(
    config: dict[str, object] | None = None,
    previous_snapshot: dict[str, object] | None = None,
) -> list[dict[str, object]]:
    payload = config if isinstance(config, dict) else load_config()
    mounted: list[dict[str, object]] = []

    try:
        root_key = str((HOST_FILESYSTEM_PATH if HOST_FILESYSTEM_PATH.exists() else Path("/")).resolve())
    except Exception:
        root_key = str(HOST_FILESYSTEM_PATH)

    seen: set[str] = {root_key}

    for fs in load_mounted_host_filesystems(payload):
        path = Path(fs["path"])
        try:
            key = str(path.resolve())
        except Exception:
            key = str(path)

        if key in seen:
            continue
        seen.add(key)

        previous_entry = previous_mounted_filesystem(
            previous_snapshot,
            fs_id=fs["id"],
            path=fs["path"],
        )
        previous_total_bytes = previous_entry.get("total_bytes") if isinstance(previous_entry, dict) else None

        mounted.append(
            measure_filesystem(
                path,
                fs_id=fs["id"],
                label=fs["label"],
                previous_total_bytes=previous_total_bytes if isinstance(previous_total_bytes, int) else None,
            )
        )

    return mounted


def mounted_filesystem_lookup(config: dict[str, object] | None = None) -> dict[str, dict[str, str]]:
    lookup: dict[str, dict[str, str]] = {}
    payload = config if isinstance(config, dict) else load_config()
    for fs in load_mounted_host_filesystems(payload):
        try:
            key = str(resolved_path(Path(fs["path"])))
        except Exception:
            key = fs["path"]
        lookup[key] = fs
    return lookup


def storage_class_label(storage_class: str) -> str:
    return STORAGE_CLASS_LABELS.get(storage_class, storage_class.replace("_", " "))


def storage_location_for_path(path: Path, config: dict[str, object] | None = None) -> dict[str, object]:
    exists = path.exists()
    is_symlink = path.is_symlink()
    real_path = resolved_path(path) if exists else path
    mount_info = mountinfo_for_path(real_path) if exists else None
    mount_point = str(mount_info.get("mount_point") or "") if mount_info else ""
    fs_lookup = mounted_filesystem_lookup(config)
    mounted_fs = fs_lookup.get(mount_point)

    if not exists:
        storage_class = "missing"
    elif mounted_fs is not None and is_symlink:
        storage_class = "symlinked_to_volume"
    elif mounted_fs is not None:
        storage_class = "mounted_volume"
    elif mount_point == "/" or not mount_point:
        storage_class = "root_disk"
    else:
        storage_class = "other_mount"

    payload: dict[str, object] = {
        "class": storage_class,
        "label": storage_class_label(storage_class),
        "path": str(path),
        "real_path": str(real_path),
        "is_symlink": is_symlink,
        "is_root_resident": storage_class == "root_disk",
        "is_volume_backed": storage_class in {"mounted_volume", "symlinked_to_volume"},
    }

    if mount_info is not None:
        payload["mount_point"] = mount_info.get("mount_point")
        payload["device_source"] = mount_info.get("device_source")
        payload["filesystem_type"] = mount_info.get("filesystem_type")
    if mounted_fs is not None:
        payload["volume_id"] = mounted_fs.get("id")
        payload["volume_label"] = mounted_fs.get("label")
    return payload


def storage_byte_key(storage_class: str) -> str:
    if storage_class == "root_disk":
        return "root_resident_bytes"
    if storage_class == "symlinked_to_volume":
        return "symlinked_to_volume_bytes"
    if storage_class == "mounted_volume":
        return "mounted_volume_bytes"
    if storage_class == "other_mount":
        return "other_mount_bytes"
    return "unknown_storage_bytes"


def measure_path(path: Path) -> dict[str, int]:
    try:
        return {
            "disk_bytes": run_bytes_command(["du", "-sB1", "-x", str(path)]),
            "apparent_bytes": run_bytes_command(["du", "-sb", "-x", str(path)]),
            "file_count": count_files(path),
        }
    except subprocess.CalledProcessError:
        return walk_path_usage(path)


def explicit_bucket_paths(root: Path, storage_config: dict[str, object]) -> dict[str, list[Path]]:
    buckets: dict[str, list[Path]] = {bucket_id: [] for bucket_id in BUCKET_ORDER if bucket_id != "source"}
    raw_buckets = storage_config.get("buckets")
    if not isinstance(raw_buckets, dict):
        return buckets

    for bucket_id, raw_paths in raw_buckets.items():
        if bucket_id not in buckets or not isinstance(raw_paths, list):
            continue
        for raw_path in raw_paths:
            path_text = str(raw_path).strip()
            if not path_text:
                continue
            candidate = Path(path_text)
            if not candidate.is_absolute():
                candidate = root / candidate
            if candidate.exists():
                buckets[bucket_id].append(candidate)
    return buckets


def auto_bucket_paths(root: Path) -> dict[str, list[Path]]:
    buckets: dict[str, list[Path]] = {bucket_id: [] for bucket_id in BUCKET_ORDER if bucket_id != "source"}
    try:
        root_dev = root.stat().st_dev
    except OSError:
        return buckets

    for dirpath, dirnames, _filenames in os.walk(root, topdown=True, followlinks=False):
        current_dir = Path(dirpath)
        kept: list[str] = []
        for name in dirnames:
            child = current_dir / name
            try:
                if child.is_symlink():
                    continue
                st = child.stat(follow_symlinks=False)
            except OSError:
                continue
            if st.st_dev != root_dev:
                continue
            if name in BUCKET_BY_DIR_NAME:
                buckets[BUCKET_BY_DIR_NAME[name]].append(child)
                continue
            kept.append(name)
        dirnames[:] = kept
    return buckets


def measure_buckets(root: Path, storage_config: dict[str, object]) -> dict[str, dict[str, object]]:
    discover_buckets = storage_config.get("discover_buckets")
    should_discover = discover_buckets is not False

    matched_paths: dict[str, list[Path]] = {bucket_id: [] for bucket_id in BUCKET_ORDER if bucket_id != "source"}
    if should_discover:
        for bucket_id, paths in auto_bucket_paths(root).items():
            matched_paths[bucket_id].extend(paths)
    for bucket_id, paths in explicit_bucket_paths(root, storage_config).items():
        matched_paths[bucket_id].extend(paths)

    buckets: dict[str, dict[str, object]] = {}
    for bucket_id in matched_paths:
        unique = unique_paths(matched_paths[bucket_id])
        if not unique:
            continue
        totals = bucket_template(bucket_id)
        totals["match_count"] = len(unique)
        for path in unique:
            measured = measure_path(path)
            totals["disk_bytes"] = int(totals["disk_bytes"]) + measured["disk_bytes"]
            totals["apparent_bytes"] = int(totals["apparent_bytes"]) + measured["apparent_bytes"]
            totals["file_count"] = int(totals["file_count"]) + measured["file_count"]
        buckets[bucket_id] = totals
    return buckets


def add_source_bucket(
    total_disk: int,
    total_apparent: int,
    total_files: int,
    buckets: dict[str, dict[str, object]],
) -> dict[str, dict[str, object]]:
    other_disk = sum(int(bucket.get("disk_bytes", 0)) for bucket in buckets.values())
    other_apparent = sum(int(bucket.get("apparent_bytes", 0)) for bucket in buckets.values())
    other_files = sum(int(bucket.get("file_count", 0)) for bucket in buckets.values())

    source_bucket = bucket_template("source")
    source_bucket["disk_bytes"] = max(0, total_disk - other_disk)
    source_bucket["apparent_bytes"] = max(0, total_apparent - other_apparent)
    source_bucket["file_count"] = max(0, total_files - other_files)
    source_bucket["match_count"] = 1 if total_disk > 0 or total_apparent > 0 or total_files > 0 else 0
    buckets["source"] = source_bucket
    return buckets


def measure_root(root_path: str, storage_config: dict[str, object] | None = None) -> dict[str, object]:
    storage = storage_config if isinstance(storage_config, dict) else {}
    root = Path(root_path)
    root_label = root.name or root_path.rstrip("/").split("/")[-1] or root_path
    storage_location = storage_location_for_path(root, load_config())
    if not root.exists():
        return {
            "label": root_label,
            "path": root_path,
            "real_path": str(root),
            "exists": False,
            "storage_location": storage_location,
            "buckets": {},
        }

    measure_root_path = resolved_path(root)
    total = measure_path(measure_root_path)
    buckets = add_source_bucket(
        total["disk_bytes"],
        total["apparent_bytes"],
        total["file_count"],
        measure_buckets(measure_root_path, storage),
    )
    return {
        "label": root_label,
        "path": root_path,
        "real_path": str(measure_root_path),
        "exists": True,
        "disk_bytes": total["disk_bytes"],
        "apparent_bytes": total["apparent_bytes"],
        "file_count": total["file_count"],
        "storage_location": storage_location,
        "buckets": buckets,
        "largest_dirs": largest_dirs(measure_root_path, root_label),
    }


def previous_project_snapshot(previous_snapshot: dict[str, object] | None, project_id: str) -> dict[str, object] | None:
    if not isinstance(previous_snapshot, dict):
        return None
    projects = previous_snapshot.get("projects")
    if not isinstance(projects, dict):
        return None
    previous = projects.get(project_id)
    return previous if isinstance(previous, dict) else None


def project_growth_fields(
    project_payload: dict[str, object],
    total_disk: int,
    total_apparent: int,
    total_files: int,
    previous_payload: dict[str, object] | None,
) -> None:
    if not isinstance(previous_payload, dict):
        return
    previous_measured_at = previous_payload.get("measured_at")
    if not isinstance(previous_measured_at, str) or not previous_measured_at.strip():
        return
    previous_disk = previous_payload.get("disk_bytes")
    previous_apparent = previous_payload.get("apparent_bytes")
    previous_files = previous_payload.get("file_count")
    if not isinstance(previous_disk, int) or not isinstance(previous_apparent, int) or not isinstance(previous_files, int):
        return

    project_payload["previous_measured_at"] = previous_measured_at
    project_payload["delta_disk_bytes"] = total_disk - previous_disk
    project_payload["delta_apparent_bytes"] = total_apparent - previous_apparent
    project_payload["delta_file_count"] = total_files - previous_files


def consumer_category_for_bucket(bucket_id: str) -> str:
    return BUCKET_ROOT_CONSUMER_CATEGORY.get(bucket_id, "live_runtime_project")


def root_consumer_row(
    *,
    project_id: str,
    project_label: str,
    root_data: dict[str, object],
    bucket_id: str,
    bucket: dict[str, object],
) -> dict[str, object] | None:
    disk_bytes = bucket.get("disk_bytes")
    if not isinstance(disk_bytes, int) or disk_bytes <= 0:
        return None

    category = consumer_category_for_bucket(bucket_id)
    root_path = str(root_data.get("path") or root_data.get("real_path") or "")
    storage_location = root_data.get("storage_location") if isinstance(root_data.get("storage_location"), dict) else {}
    return {
        "id": f"{project_id}:{bucket_id}:{root_path}",
        "project_id": project_id,
        "project_label": project_label,
        "path": root_path,
        "real_path": str(root_data.get("real_path") or root_path),
        "label": str(bucket.get("label") or BUCKET_LABELS.get(bucket_id) or bucket_id),
        "bytes": disk_bytes,
        "bucket": bucket_id,
        "category": category,
        "category_label": ROOT_CONSUMER_CATEGORY_LABELS.get(category, category.replace("_", " ")),
        "reclaimability": ROOT_CONSUMER_RECLAIMABILITY.get(category, "unknown"),
        "storage_class": str(storage_location.get("class") or "unknown"),
        "storage_label": str(storage_location.get("label") or "unknown storage"),
    }


def root_residency_template() -> dict[str, object]:
    return {
        "root_resident_bytes": 0,
        "mounted_volume_bytes": 0,
        "symlinked_to_volume_bytes": 0,
        "volume_backed_bytes": 0,
        "other_mount_bytes": 0,
        "unknown_storage_bytes": 0,
        "top_root_projects": [],
        "top_consumers": [],
        "category_totals": [],
    }


def add_root_consumer_totals(
    category_totals: dict[str, dict[str, object]],
    row: dict[str, object],
) -> None:
    category = str(row.get("category") or "live_runtime_project")
    total = category_totals.setdefault(
        category,
        {
            "key": category,
            "label": ROOT_CONSUMER_CATEGORY_LABELS.get(category, category.replace("_", " ")),
            "bytes": 0,
            "count": 0,
        },
    )
    total["bytes"] = int(total.get("bytes", 0)) + int(row.get("bytes", 0))
    total["count"] = int(total.get("count", 0)) + 1


def storage_class_for_project(byte_splits: dict[str, int]) -> str:
    present: list[str] = []
    if byte_splits.get("root_resident_bytes", 0) > 0:
        present.append("root_disk")
    if byte_splits.get("symlinked_to_volume_bytes", 0) > 0:
        present.append("symlinked_to_volume")
    if byte_splits.get("mounted_volume_bytes", 0) > 0:
        present.append("mounted_volume")
    if byte_splits.get("other_mount_bytes", 0) > 0:
        present.append("other_mount")
    if not present:
        return "missing"
    if len(present) == 1:
        return present[0]
    return "mixed"


def storage_label_for_project(storage_class: str) -> str:
    if storage_class == "mixed":
        return "mixed storage"
    return storage_class_label(storage_class)


def projectish_marker_paths(path: Path) -> list[str]:
    markers = {
        ".git",
        "package.json",
        "pyproject.toml",
        "go.mod",
        "Cargo.toml",
        "composer.json",
        "requirements.txt",
    }
    out: list[str] = []

    for marker in markers:
        candidate = path / marker
        try:
            exists = candidate.exists()
        except OSError:
            exists = False
        if exists:
            out.append(str(candidate))

    try:
        children = [child for child in path.iterdir() if child.is_dir() and not child.is_symlink()]
    except OSError:
        children = []

    ignored = {"node_modules", ".next", "dist", "build", ".cache", ".venv", "venv", "__pycache__"}
    for child in children:
        if child.name in ignored or child.name.startswith("."):
            continue
        for marker in markers:
            candidate = child / marker
            try:
                exists = candidate.exists()
            except OSError:
                exists = False
            if exists:
                out.append(str(candidate))
                break

    return out[:8]


def is_projectish_dir(path: Path) -> bool:
    return len(projectish_marker_paths(path)) > 0


def configured_project_paths(config: dict[str, object]) -> set[str]:
    out: set[str] = set()
    for project in load_projects(config):
        storage = project.get("storage")
        if not isinstance(storage, dict):
            continue
        roots = storage.get("roots")
        if not isinstance(roots, list):
            continue
        for raw_root in roots:
            if not isinstance(raw_root, str) or not raw_root.strip():
                continue
            path = Path(raw_root.strip())
            out.add(str(path))
            try:
                out.add(str(resolved_path(path)))
            except Exception:
                pass
    return out


def discovery_roots(config: dict[str, object]) -> list[Path]:
    configured = parse_csv_paths(PROJECT_DISCOVERY_ROOTS)
    if configured:
        return [path for path in configured if path.exists() and path.is_dir()]

    roots = [Path("/var/www")]
    for fs in load_mounted_host_filesystems(config):
        mounted_path = Path(fs["path"])
        roots.append(mounted_path)
        roots.append(mounted_path / "www-moved")

    unique: list[Path] = []
    seen: set[str] = set()
    for root in roots:
        if not root.exists() or not root.is_dir():
            continue
        key = str(resolved_path(root))
        if key in seen:
            continue
        seen.add(key)
        unique.append(root)
    return unique


def slug_for_project_name(name: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", name.strip().lower()).strip("-")
    return slug or "project"


def discover_untracked_projects(config: dict[str, object]) -> dict[str, object]:
    known = configured_project_paths(config)
    candidates: list[dict[str, object]] = []
    seen_real_paths: set[str] = set()

    for root in discovery_roots(config):
        try:
            children = sorted(root.iterdir(), key=lambda item: item.name.lower())
        except OSError:
            continue

        for child in children:
            try:
                child_exists = child.exists()
                child_is_dir = child.is_dir()
            except OSError:
                continue
            if not child_exists or not child_is_dir:
                continue
            if child.name.startswith(".") or child.name in {"html", "_letsencrypt", "venv", "node_modules"}:
                continue

            real_child = resolved_path(child)
            child_key = str(child)
            real_key = str(real_child)
            if child_key in known or real_key in known or real_key in seen_real_paths:
                continue
            if not is_projectish_dir(real_child):
                continue

            seen_real_paths.add(real_key)
            markers = projectish_marker_paths(real_child)
            candidates.append(
                {
                    "id": slug_for_project_name(child.name),
                    "label": child.name,
                    "path": child_key,
                    "real_path": real_key,
                    "scope": "vps",
                    "state": "untracked",
                    "storage_location": storage_location_for_path(child, config),
                    "marker_paths": markers,
                    "suggested_tracking": {
                        "vps_roots": [child_key],
                        "local_roots": [],
                        "note": "VPS discovery is host-side. Local MBP tracking needs a local command or committed registry entry.",
                    },
                }
            )

    candidates.sort(key=lambda item: str(item.get("label") or "").lower())
    return {
        "scope": "vps",
        "mode": "host_scan",
        "root_paths": [str(path) for path in discovery_roots(config)],
        "candidates": candidates[:24],
    }


def build_snapshot(previous_snapshot: dict[str, object] | None = None) -> dict[str, object]:
    measured_at = iso_utc_now()
    config = load_config()
    projects_payload: dict[str, object] = {}
    root_residency = root_residency_template()
    root_project_rows: list[dict[str, object]] = []
    root_consumer_rows: list[dict[str, object]] = []
    root_category_totals: dict[str, dict[str, object]] = {}

    for project in load_projects(config):
        project_id = str(project.get("id", "")).strip()
        if not project_id:
            continue
        storage = project.get("storage")
        if not isinstance(storage, dict):
            continue
        roots_raw = storage.get("roots")
        if not isinstance(roots_raw, list):
            continue

        roots = [str(root).strip() for root in roots_raw if str(root).strip()]
        if not roots:
            continue

        measured_roots: list[dict[str, object]] = []
        largest: list[dict[str, object]] = []
        total_disk = 0
        total_apparent = 0
        total_files = 0
        roots_present = 0
        project_buckets: dict[str, dict[str, object]] = {}
        project_byte_splits: dict[str, int] = {
            "root_resident_bytes": 0,
            "mounted_volume_bytes": 0,
            "symlinked_to_volume_bytes": 0,
            "other_mount_bytes": 0,
            "unknown_storage_bytes": 0,
        }

        for root_path in roots:
            root_data = measure_root(root_path, storage)
            measured_roots.append(root_data)
            if not root_data.get("exists"):
                continue
            roots_present += 1
            root_disk_bytes = int(root_data.get("disk_bytes", 0))
            total_disk += root_disk_bytes
            total_apparent += int(root_data.get("apparent_bytes", 0))
            total_files += int(root_data.get("file_count", 0))
            largest.extend(root_data.get("largest_dirs", []))
            storage_location = root_data.get("storage_location")
            storage_class = (
                str(storage_location.get("class") or "unknown")
                if isinstance(storage_location, dict)
                else "unknown"
            )
            split_key = storage_byte_key(storage_class)
            project_byte_splits[split_key] = project_byte_splits.get(split_key, 0) + root_disk_bytes
            root_residency[split_key] = int(root_residency.get(split_key, 0)) + root_disk_bytes
            if storage_class in {"mounted_volume", "symlinked_to_volume"}:
                root_residency["volume_backed_bytes"] = int(root_residency.get("volume_backed_bytes", 0)) + root_disk_bytes

            if storage_class == "root_disk" and root_disk_bytes > 0:
                root_project_rows.append(
                    {
                        "project_id": project_id,
                        "project_label": str(project.get("label") or project_id),
                        "path": str(root_data.get("path") or root_path),
                        "real_path": str(root_data.get("real_path") or root_path),
                        "bytes": root_disk_bytes,
                        "storage_class": storage_class,
                        "storage_label": storage_class_label(storage_class),
                    }
                )

            raw_buckets = root_data.get("buckets")
            if isinstance(raw_buckets, dict):
                for bucket_id, raw_bucket in raw_buckets.items():
                    if bucket_id not in BUCKET_ORDER or not isinstance(raw_bucket, dict):
                        continue
                    bucket = project_buckets.setdefault(bucket_id, bucket_template(bucket_id))
                    bucket["disk_bytes"] = int(bucket.get("disk_bytes", 0)) + int(raw_bucket.get("disk_bytes", 0))
                    bucket["apparent_bytes"] = int(bucket.get("apparent_bytes", 0)) + int(raw_bucket.get("apparent_bytes", 0))
                    bucket["file_count"] = int(bucket.get("file_count", 0)) + int(raw_bucket.get("file_count", 0))
                    bucket["match_count"] = int(bucket.get("match_count", 0)) + int(raw_bucket.get("match_count", 0))
                    if storage_class == "root_disk":
                        consumer = root_consumer_row(
                            project_id=project_id,
                            project_label=str(project.get("label") or project_id),
                            root_data=root_data,
                            bucket_id=bucket_id,
                            bucket=raw_bucket,
                        )
                        if consumer is not None:
                            root_consumer_rows.append(consumer)
                            add_root_consumer_totals(root_category_totals, consumer)

        largest.sort(key=lambda item: int(item.get("disk_bytes", 0)), reverse=True)

        project_payload: dict[str, object] = {
            "id": project_id,
            "label": project.get("label") or project_id,
            "measured_at": measured_at,
            "roots_configured": len(roots),
            "roots_present": roots_present,
            "roots": measured_roots,
            "largest_dirs": largest[:TOP_DIR_LIMIT],
            "buckets": {
                bucket_id: project_buckets[bucket_id]
                for bucket_id in BUCKET_ORDER
                if bucket_id in project_buckets
            },
            "root_resident_bytes": project_byte_splits.get("root_resident_bytes", 0),
            "mounted_volume_bytes": project_byte_splits.get("mounted_volume_bytes", 0),
            "symlinked_to_volume_bytes": project_byte_splits.get("symlinked_to_volume_bytes", 0),
            "volume_backed_bytes": project_byte_splits.get("mounted_volume_bytes", 0)
            + project_byte_splits.get("symlinked_to_volume_bytes", 0),
            "other_mount_bytes": project_byte_splits.get("other_mount_bytes", 0),
        }
        project_storage_class = storage_class_for_project(project_byte_splits)
        project_payload["storage_class"] = project_storage_class
        project_payload["storage_label"] = storage_label_for_project(project_storage_class)

        if roots_present > 0:
            project_payload["disk_bytes"] = total_disk
            project_payload["apparent_bytes"] = total_apparent
            project_payload["file_count"] = total_files
            project_growth_fields(
                project_payload,
                total_disk,
                total_apparent,
                total_files,
                previous_project_snapshot(previous_snapshot, project_id),
            )

        projects_payload[project_id] = project_payload

    root_project_rows.sort(key=lambda item: int(item.get("bytes", 0)), reverse=True)
    root_consumer_rows.sort(key=lambda item: int(item.get("bytes", 0)), reverse=True)
    root_residency["top_root_projects"] = root_project_rows[:TOP_DIR_LIMIT]
    root_residency["top_consumers"] = root_consumer_rows[: max(TOP_DIR_LIMIT, 8)]
    root_residency["category_totals"] = sorted(
        root_category_totals.values(),
        key=lambda item: int(item.get("bytes", 0)),
        reverse=True,
    )

    return {
        "schema_version": SCHEMA_VERSION,
        "measured_at": measured_at,
        "ttl_seconds": TTL_SECONDS,
        "top_dirs_limit": TOP_DIR_LIMIT,
        "top_dirs_depth": TOP_DIR_DEPTH,
        "bucket_order": BUCKET_ORDER,
        "host_filesystem": measure_host_filesystem(),
        "mounted_filesystems": measure_mounted_filesystems(config, previous_snapshot),
        "root_residency": root_residency,
        "discovery": discover_untracked_projects(config),
        "projects": projects_payload,
    }


def load_snapshot(path: Path, *, enforce_ttl: bool) -> dict[str, object] | None:
    if not path.exists():
        return None
    try:
        payload = json.loads(path.read_text())
    except Exception as exc:
        log(f"warn: failed to parse snapshot {path}: {exc}")
        return None
    if int(payload.get("schema_version", 0) or 0) != SCHEMA_VERSION:
        return None
    measured_at = parse_iso(payload.get("measured_at"))
    if measured_at is None:
        return None
    if enforce_ttl:
        age_seconds = (datetime.now(timezone.utc) - measured_at.astimezone(timezone.utc)).total_seconds()
        if age_seconds > TTL_SECONDS:
            return None
    return payload if isinstance(payload, dict) else None


def load_cached_snapshot() -> dict[str, object] | None:
    return load_snapshot(CACHE_JSON, enforce_ttl=True)


def load_previous_snapshot() -> dict[str, object] | None:
    return load_snapshot(CACHE_JSON, enforce_ttl=False)


def write_json(path: Path, payload: dict[str, object], mode: int) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False) as handle:
        json.dump(payload, handle, indent=2, sort_keys=True)
        handle.write("\n")
        tmp_name = handle.name
    os.chmod(tmp_name, mode)
    os.replace(tmp_name, path)


def build_storage_alerts(snapshot: dict[str, object]) -> list[dict[str, object]]:
    alerts: list[dict[str, object]] = []

    host_filesystem = snapshot.get("host_filesystem")
    if isinstance(host_filesystem, dict):
        used_percent = host_filesystem.get("used_percent")
        available_bytes = host_filesystem.get("available_bytes")
        used_bytes = host_filesystem.get("used_bytes")
        total_bytes = host_filesystem.get("total_bytes")
        path = str(host_filesystem.get("path") or "/").strip() or "/"
        if isinstance(used_percent, (int, float)) and isinstance(available_bytes, int) and isinstance(used_bytes, int) and isinstance(total_bytes, int):
            severity = None
            code = None
            if used_percent >= HOST_DISK_FAIL_PCT:
                severity = "critical"
                code = "host_disk_critical"
            elif used_percent >= HOST_DISK_WARN_PCT:
                severity = "warn"
                code = "host_disk_warn"
            if severity and code:
                alerts.append(
                    {
                        "title": "Host disk pressure",
                        "detail": f"{path} is {used_percent:.1f}% used with {fmt_bytes(available_bytes)} free ({fmt_bytes(used_bytes)} of {fmt_bytes(total_bytes)} used).",
                        "severity": severity,
                        "code": code,
                        "project": "vps-host",
                        "path": path,
                    }
                )

    projects = snapshot.get("projects")
    if isinstance(projects, dict):
        for project_id, raw_project in projects.items():
            if not isinstance(raw_project, dict):
                continue
            delta_disk = raw_project.get("delta_disk_bytes")
            total_disk = raw_project.get("disk_bytes")
            previous_measured_at = raw_project.get("previous_measured_at")
            if not isinstance(delta_disk, int) or delta_disk <= 0 or not isinstance(total_disk, int):
                continue
            if not isinstance(previous_measured_at, str) or not previous_measured_at.strip():
                continue

            severity = None
            code = None
            if delta_disk >= PROJECT_GROWTH_FAIL_BYTES:
                severity = "critical"
                code = "project_disk_growth_critical"
            elif delta_disk >= PROJECT_GROWTH_WARN_BYTES:
                severity = "warn"
                code = "project_disk_growth_warn"
            if severity is None or code is None:
                continue

            label = str(raw_project.get("label") or project_id)
            age = age_label(previous_measured_at, raw_project.get("measured_at"))
            interval = f" over {age}" if age else ""
            alerts.append(
                {
                    "title": f"{label} disk usage grew sharply",
                    "detail": f"{label} grew by {fmt_bytes(delta_disk)}{interval} and now uses {fmt_bytes(total_disk)} on tracked project roots.",
                    "severity": severity,
                    "code": code,
                    "project": project_id,
                }
            )

    return alerts


def merge_into_last(snapshot: dict[str, object], storage_alerts: list[dict[str, object]]) -> None:
    if not LAST_JSON.exists():
        log(f"warn: missing {LAST_JSON}; skipping merge")
        return
    payload = json.loads(LAST_JSON.read_text())
    if not isinstance(payload, dict):
        log(f"warn: {LAST_JSON} did not contain an object; skipping merge")
        return
    existing_alerts = payload.get("alerts")
    alerts = existing_alerts if isinstance(existing_alerts, list) else []
    filtered_alerts = []
    for alert in alerts:
        if not isinstance(alert, dict):
            continue
        code = str(alert.get("code") or "").strip()
        if code in PROJECT_STORAGE_ALERT_CODES:
            continue
        filtered_alerts.append(alert)
    filtered_alerts.extend(storage_alerts)
    payload["alerts"] = filtered_alerts
    payload["alerts_count"] = len(filtered_alerts)
    payload["project_storage"] = snapshot
    write_json(LAST_JSON, payload, 0o644)


def main() -> int:
    if not LAST_JSON.exists():
        log(f"warn: missing {LAST_JSON}; nothing to do")
        return 0

    STATE_DIR.mkdir(parents=True, exist_ok=True)
    lock_handle = LOCK_FILE.open("a+")
    try:
        import fcntl

        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
    except Exception as exc:
        log(f"warn: lock unavailable, continuing without it: {exc}")

    config = load_config()
    previous_snapshot = load_previous_snapshot()
    snapshot = load_cached_snapshot()
    if snapshot is None:
        snapshot = build_snapshot(previous_snapshot)
        try:
            write_json(CACHE_JSON, snapshot, 0o600)
        except Exception as exc:
            log(f"warn: failed to write cache {CACHE_JSON}: {exc}")
    else:
        log("using cached project storage snapshot")
        snapshot["host_filesystem"] = measure_host_filesystem()
        snapshot["mounted_filesystems"] = measure_mounted_filesystems(config, previous_snapshot)

    storage_alerts = build_storage_alerts(snapshot)

    try:
        merge_into_last(snapshot, storage_alerts)
    except Exception as exc:
        log(f"warn: failed to merge project storage into {LAST_JSON}: {exc}")
        return 0

    projects = snapshot.get("projects", {})
    measured_count = len(projects) if isinstance(projects, dict) else 0
    log(f"ok: merged project storage for {measured_count} project(s) alerts={len(storage_alerts)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
